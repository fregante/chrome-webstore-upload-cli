{
  "name": "chrome-webstore-upload-cli",
  "version": "4.0.0-0",
  "description": "CLI tool to upload Chrome Extensions to the Chrome Web Store",
  "keywords": [
    "chrome",
    "publish",
    "webstore",
    "store",
    "extension",
    "deploy",
    "update",
    "upload",
    "cli"
  ],
  "repository": "fregante/chrome-webstore-upload-cli",
  "funding": "https://github.com/sponsors/fregante",
  "license": "MIT",
  "author": "Andrew Levine",
  "contributors": [
    "Federico Brigante <me@fregante.com> (https://fregante.com)"
  ],
  "type": "module",
  "bin": {
    "chrome-webstore-upload": "source/cli.js"
  },
  "scripts": {
    "test": "xo && ava"
  },
  "xo": {
    "ignores": [
      "test/fixtures/**"
    ],
    "rules": {
      "@stylistic/object-curly-spacing": [
        "error",
        "always"
      ],
      "@stylistic/function-paren-newline": "off",
      "@stylistic/object-curly-newline": "off",
      "@stylistic/curly-newline": "off",
      "require-unicode-regexp": "off",
      "unicorn/import-style": "off",
      "unicorn/no-empty-file": "off",
      "ava/prefer-t-throws": "off",
      "ava/no-conditional-assertion": "off",
      "ava/no-useless-t-pass": "off"
    },
    "space": 4
  },
  "ava": {
    "files": [
      "source/**/*.test.js",
      "!test/fixtures/**",
      "!test/helpers/**"
    ]
  },
  "dependencies": {
    "chrome-webstore-upload": "^4.0.3",
    "meow": "^14.1.0"
  },
  "devDependencies": {
    "ava": "^7.0.0",
    "execa": "^9.6.1",
    "mock-fs": "^5.5.0",
    "xo": "^2.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}
